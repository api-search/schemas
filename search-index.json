---
layout: none
---
[
{% assign idx = 0 %}{% for schema in site.schemas %}{
"i":{{ idx }},
"type":"schema",
"n":{{ schema.title | default: schema.name | jsonify }},
"d":{{ schema.description | strip_html | strip_newlines | truncate: 300 | jsonify }},
"t":{{ schema.tags | jsonify }},
"p":{{ schema.provider_name | default: schema.provider_slug | jsonify }},
"ps":{{ schema.provider_slug | jsonify }},
"u":"{{ schema.url | absolute_url }}"
}{% assign idx = idx | plus: 1 %}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
